{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/karakana_session_start.sh\"",
            "timeout": 30,
            "statusMessage": "Loading Karakana handoff"
          }
        ]
      }
    ]
  }
}
